{
  "name": "@notes-app/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@notes-app/common": "workspace:*",
    "@notes-app/ui": "workspace:*",
    "@notes-app/vault": "workspace:*",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.notes-app.desktop",
    "productName": "Notes",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    }
  }
}
